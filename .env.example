# ----------------------------------------------------------------
# MahaFarm frontend (Vite) — environment variables
# Copy to ".env" to override. All client vars must start with VITE_.
# ----------------------------------------------------------------

# Base URL of the MahaFarm API (Phase 2 backend)
VITE_API_BASE_URL=http://localhost:5000/api

# Data source:
#   true  → run the UI on built-in mock data (no backend needed)
#   false → talk to the real API at VITE_API_BASE_URL (run the server + seed first)
VITE_ENABLE_MOCK_DATA=true
