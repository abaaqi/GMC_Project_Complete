# ----------------------------------------------------------------
# MahaFarm API — environment variables (Phase 2)
# Copy this file to ".env" and adjust values for your machine.
# ----------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=5000

# Database — a local MongoDB or a MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/mahafarm

# Auth / sessions
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Set true in production (HTTPS) so the session cookie is Secure + SameSite=None
COOKIE_SECURE=false

# Where the Phase 1 frontend runs (used for CORS + cookies)
CLIENT_URL=http://localhost:5173
